    },
    "soap": {
      "v2": {
        "supported": {
          "TransactionID": "capture_id",
          "Amount": "amount.value",
          "Amount.currencyID": "amount.currency_code",
          "RefundType": "Mapped to amount presence",
          "Note": "note_to_payer",
          "InvoiceID": "invoice_id"
        },
        "not_supported": [
          "RefundSource",
          "MsgSubID"
        ]
      }
