        ]
      }
    }
  },
  "special_notes": {
    "v2_usage": "Use for one-time checkout flows with Orders API",
    "v3_usage": "Use for billing agreements with Vault API",
    "migration_tips": [
      "NOTIFYURL is replaced with Webhooks - no direct field mapping",
      "PAYMENTACTION maps to Orders API intent field (CAPTURE/AUTHORIZE)",
      "TOKEN parameter becomes PayPal-Request-Id header",
      "BUTTONSOURCE becomes PayPal-Partner-Attribution-Id header"
    ],
    "value_based_mappings": {
      "shipping_preference": {
        "NOSHIPPING=1": "payment_source.paypal.experience_context.shipping_preference='NO_SHIPPING'",
        "NOSHIPPING=0 AND ADDROVERRIDE=1": "payment_source.paypal.experience_context.shipping_preference='SET_PROVIDED_ADDRESS'",
        "NOSHIPPING=0 AND ADDROVERRIDE=0": "payment_source.paypal.experience_context.shipping_preference='GET_FROM_FILE'"
      },
      "payment_intent": {
        "PAYMENTACTION=SALE": "intent='CAPTURE'",
        "PAYMENTACTION=AUTHORIZATION": "intent='AUTHORIZE'",
        "PAYMENTREQUEST_n_PAYMENTACTION=SALE": "intent='CAPTURE'",
        "PAYMENTREQUEST_n_PAYMENTACTION=AUTHORIZATION": "intent='AUTHORIZE'"
      },
      "soap_equivalents": {
        "NoShipping=1": "payment_source.paypal.experience_context.shipping_preference='NO_SHIPPING'",
        "NoShipping=0 AND AddressOverride=1": "payment_source.paypal.experience_context.shipping_preference='SET_PROVIDED_ADDRESS'",
        "NoShipping=0 AND AddressOverride=0": "payment_source.paypal.experience_context.shipping_preference='GET_FROM_FILE'",
        "PaymentDetails.PaymentAction=SALE": "intent='CAPTURE'",
        "PaymentDetails.PaymentAction=AUTHORIZATION": "intent='AUTHORIZE'"
      }
    },
    "rest_augmentations": {
      "billing_agreement_with_purchase": {
        "description": "Add to Orders v2 payload for billing agreements with initial purchase",
        "payload": {
          "payment_source": {
            "paypal": {
              "attributes": {
                "vault": {
                  "store_in_vault": "ON_SUCCESS",
                  "usage_type": "MERCHANT"
                }
              }
            }
          }
        }
      },
      "billing_agreement_without_purchase": {
        "description": "Add to Vault v3 payload for billing agreements without initial purchase",
        "payload": {
          "payment_source": {
            "paypal": {
              "usage_pattern": "IMMEDIATE",
              "usage_type": "MERCHANT"
            }
          }
        }
      }
    },
    "deprecated_fields": {
      "application_context": {
        "reason": "Replaced by payment_source.paypal.experience_context in REST APIs",
        "replacement": "payment_source.paypal.experience_context",
        "examples": {
          "never_use": {
            "application_context": {
              "return_url": "...",
              "cancel_url": "...",
              "brand_name": "..."
            }
          },
          "always_use": {
            "payment_source": {
              "paypal": {
                "experience_context": {
                  "return_url": "...",
                  "cancel_url": "...",
                  "brand_name": "..."
                }
              }
            }
          }
        }
      }
    }
  }
}