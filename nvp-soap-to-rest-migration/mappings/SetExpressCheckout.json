        },
        "not_supported": [
          "PaymentDetails.ProfileAddressChangeDate",
          "PaymentDetails.AllowNote",
          "MaxAmount",
          "SolutionType",
          "ReqBillingAddress"
        ]
      },
      "v3": {
        "supported": {
          "SetExpressCheckoutRequestDetails.ReturnURL": "payment_source.paypal.experience_context.return_url",
          "SetExpressCheckoutRequestDetails.CancelURL": "payment_source.paypal.experience_context.cancel_url",
          "SetExpressCheckoutRequestDetails.BrandName": "payment_source.paypal.experience_context.brand_name",
