    "soap": {
      "v2": {
        "supported": {
          "AddressOverride": "payment_source.paypal.experience_context.shipping_preference",
          "BrandName": "payment_source.paypal.experience_context.brand_name",
          "BuyerDetails.BuyerUserName": "payment_source.paypal.name.given_name",
          "BuyerDetails.TaxIdDetails.TaxId": "payment_source.paypal.tax_info.tax_id",
          "BuyerDetails.TaxIdDetails.TaxIdType": "payment_source.paypal.tax_info.tax_id_type",
          "CancelURL": "payment_source.paypal.experience_context.cancel_url",
          "LandingPage": "payment_source.paypal.experience_context.landing_page",
          "LocaleCode": "payment_source.paypal.experience_context.locale",
          "NoShipping": "payment_source.paypal.experience_context.shipping_preference",
          "ReturnURL": "payment_source.paypal.experience_context.return_url",
          "PaymentDetails.Custom": "purchase_units[].custom_id",
          "PaymentDetails.OrderDescription": "purchase_units[].description",
          "PaymentDetails.OrderTotal": "purchase_units[].amount.value",
          "PaymentDetails.OrderTotal.currencyID": "purchase_units[].amount.currency_code",
