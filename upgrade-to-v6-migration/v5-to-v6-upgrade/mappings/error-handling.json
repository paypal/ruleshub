  "error_extraction": {
    "debug_id": {
      "locations": [
        "error.details?.debug_id",
        "error.debug_id",
        "error.response?.data?.debug_id",
        "error.headers?.['paypal-debug-id']"
      ],
      "usage": "Always log debug_id for PayPal support",
      "example": "const debugId = error.details?.debug_id || error.debug_id || 'N/A';"
    },
    "error_code": {
      "locations": [
        "error.code",
        "error.response?.data?.name",
        "error.name"
      ],
      "usage": "Map to user-friendly messages",
      "example": "const errorCode = error.code || error.response?.data?.name || 'UNKNOWN_ERROR';"
    },
    "error_message": {
      "locations": [
        "error.message",
        "error.response?.data?.message",
        "error.response?.data?.details?.[0]?.issue"
      ],
      "usage": "Internal logging only (don't show to users)",
      "example": "console.error('PayPal Error:', error.message);"
    }
  },
  "error_handler_implementation": {
    "comprehensive_handler": {
      "description": "Universal error handler for all PayPal operations",
      "parameters": {
        "error": "Error object from PayPal SDK or API",
        "context": "Additional context (operation, user_id, etc.)"
      },
      "returns": "User-friendly error message",
      "actions": [
        "Extract debug_id and error_code",
        "Log comprehensive error details",
        "Map to user-friendly message",
        "Track error for monitoring",
        "Determine if error is recoverable",
        "Show retry option if recoverable",
        "Suggest alternative payment methods if needed"
      ]
    }
  },
